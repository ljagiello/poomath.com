{
	// This config is intentionally self-contained instead of extending
	// ./.svelte-kit/tsconfig.json (the usual SvelteKit pattern). Vite 8's
	// rolldown/oxc transform can't resolve a tsconfig referenced through the
	// dotted `.svelte-kit/` directory and fails the build with
	// "Tsconfig not found". `svelte-kit sync` still prints a "should extend"
	// hint — that warning is expected and safe to ignore here.
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"target": "esnext",
		"lib": ["esnext", "DOM", "DOM.Iterable"],
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"noEmit": true,
		"paths": {
			"$lib": ["./src/lib"],
			"$lib/*": ["./src/lib/*"]
		},
		// Overlay the SvelteKit-generated types dir so route `./$types` imports
		// resolve (normally provided by the .svelte-kit/tsconfig.json we don't
		// extend). These are type-only imports, erased before the rolldown build.
		"rootDirs": [".", "./.svelte-kit/types"]
	},
	"include": [
		"src/**/*.js",
		"src/**/*.ts",
		"src/**/*.d.ts",
		"src/**/*.svelte",
		"vite.config.ts",
		".svelte-kit/ambient.d.ts",
		".svelte-kit/types/**/$types.d.ts"
	]
}
